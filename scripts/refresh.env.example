# Config for refresh-install.sh — copy to scripts/refresh.env and fill in.
# scripts/refresh.env is gitignored (machine-specific ids).

# Paired iPhone identifier. Find it with:  xcrun devicectl list devices
DEVICE_ID="653E0E83-E30B-5C88-803B-E48719841859"

# Apple Developer team id used to sign the on-device build.
#   - Paid account (current):        7RN999S858
#   - After switching to Free:        your PERSONAL team id (10 chars). Find it in
#     Xcode ▸ Settings ▸ Accounts ▸ (your Apple ID) ▸ the "Personal Team" row,
#     or from a build:  security cms -D -i "$(find build/refresh-dd -name embedded.mobileprovision | head -1)" | plutil -extract TeamIdentifier.0 raw -
TEAM_ID="7RN999S858"

# Optional: set to 1 to also get a macOS notification on SUCCESS (failures always notify).
NOTIFY_ON_SUCCESS="0"
