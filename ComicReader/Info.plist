<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Only the keys that have no INFOPLIST_KEY_ build-setting form live here.
	     Everything else (display name, scene manifest, orientations, launch screen)
	     is still generated from the INFOPLIST_KEY_* settings in project.yml and
	     merged on top of this file at build time. -->

	<!-- Let the page-turn animation run above 60 Hz on ProMotion iPhones; iOS caps
	     custom animations at 60 Hz without it, which judders next to the 120 Hz drag. -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<!-- The app uses only standard, exempt encryption (HTTPS). -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Read comics opened from Files at their source location; the importer copies
	     them into the library, so no write-back is needed. -->
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>

	<!-- Our own UTI for cbz, mapping the file extension to it (the OS otherwise
	     invents a dynamic type per app). cbz conforms to public.zip-archive. -->
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>de.wiredframe.comicreader.cbz</string>
			<key>UTTypeDescription</key>
			<string>Comic Book Archive (ZIP)</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.zip-archive</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>cbz</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/vnd.comicbook+zip</string>
					<string>application/x-cbz</string>
				</array>
			</dict>
		</dict>
	</array>

	<!-- Declare the app opens that UTI as a viewer, so it shows up in the Files
	     app ("Open"), in other apps' "Open With" / share sheet, and can be the default
	     handler. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Comic Book Archive (ZIP)</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>de.wiredframe.comicreader.cbz</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
